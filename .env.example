# Local LLM Configuration
# Copy this file to .env and update the values

# LiteLLM / OpenAI API Key (often 'none' for local providers)
OPENAI_API_KEY=none

# The base URL for your local LLM provider
# - Ollama: http://localhost:11434/v1
# - LM Studio: http://localhost:1234/v1
# - vLLM: http://localhost:8000/v1
OPENAI_BASE_URL=http://localhost:11434/v1

# The name of the model to use (LiteLLM format)
# If the provider is Ollama/LM Studio, use 'openai/model-name'
LOCAL_MODEL_NAME=qwen2.5-coder:7b

# Optional: Temperature and Max Tokens overrides
# LOCAL_LLM_TEMPERATURE=0.7
# LOCAL_LLM_MAX_TOKENS=32768
